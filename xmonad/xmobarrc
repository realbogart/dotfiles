Config
  { font = "xft:monospace:size=10"
  , bgColor = "#1f2430"
  , fgColor = "#d8dee9"
  , position = Top
  , lowerOnStart = True
  , allDesktops = True
  , persistent = True
  , commands =
      [ Run Cpu ["-t", "CPU <total>%", "-L", "20", "-H", "70", "--high", "#ff6b6b"] 20
      , Run Memory ["-t", "MEM <usedratio>%"] 20
      , Run Date "%a %Y-%m-%d %H:%M" "date" 10
      ]
  , sepChar = "%"
  , alignSep = "}{"
  , template = " %cpu% | %memory% }{ %date% "
  }
