#!/usr/bin/env sh
set -eu

apps_file="${XDG_CONFIG_HOME:-$HOME/.config}/xmonad/launcher-apps.tsv"
theme_file="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/config.rasi"
icon_dir="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/icons"

[ -f "$apps_file" ] || exit 1

choice="$(
  while IFS='	' read -r label _cmd icon || [ -n "${label:-}" ]; do
    case "${label:-}" in
      ''|\#*)
        continue
        ;;
    esac

    if [ -n "${icon:-}" ]; then
      icon_value="$icon"
      if [ -f "$icon_dir/$icon.svg" ]; then
        icon_value="$icon_dir/$icon.svg"
      elif [ -f "$icon_dir/$icon.png" ]; then
        icon_value="$icon_dir/$icon.png"
      fi
      printf '%s\0icon\x1f%s\n' "$label" "$icon_value"
    else
      printf '%s\n' "$label"
    fi
  done < "$apps_file" | rofi -dmenu -i -show-icons -p "Apps" -theme "$theme_file"
)"

[ -n "$choice" ] || exit 0

cmd="$(
  awk -F '\t' -v wanted="$choice" '
    /^[[:space:]]*$/ { next }
    /^[[:space:]]*#/ { next }
    $1 == wanted {
      print $2
      exit
    }
  ' "$apps_file"
)"

[ -n "$cmd" ] || exit 1
exec sh -lc "$cmd"
